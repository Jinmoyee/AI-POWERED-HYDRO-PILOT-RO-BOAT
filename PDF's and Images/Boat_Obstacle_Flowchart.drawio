<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="BoatObstacleFlowchart">
    <mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Start Node -->
        <mxCell id="start" value="Start" style="ellipse;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="300" y="50" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- ESP32 #1 Initialization -->
        <mxCell id="esp1_init" value="Initialize Ultrasonic & Motors" style="rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="250" y="120" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="start_to_esp1_init" edge="1" parent="1" source="start" target="esp1_init">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ESP32 #1 Loop -->
        <mxCell id="esp1_loop" value="Read Distance & Control Motors" style="rounded=1;fillColor=#FFF2CC;strokeColor=#D6B656;" vertex="1" parent="1">
          <mxGeometry x="250" y="190" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="esp1_init_to_loop" edge="1" parent="1" source="esp1_init" target="esp1_loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ESP32 #2 Reads Data -->
        <mxCell id="esp2_read" value="ESP32 #2 Reads Data & Controls Servo" style="rounded=1;fillColor=#F8CECC;strokeColor=#B85450;" vertex="1" parent="1">
          <mxGeometry x="250" y="260" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="esp1_loop_to_esp2_read" edge="1" parent="1" source="esp1_loop" target="esp2_read">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision Making -->
        <mxCell id="decision" value="Obstacle Detected?" style="rhombus;fillColor=#E1D5E7;strokeColor=#9673A6;" vertex="1" parent="1">
          <mxGeometry x="300" y="330" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="esp2_read_to_decision" edge="1" parent="1" source="esp2_read" target="decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Yes (Change Servo Angle) -->
        <mxCell id="change_servo" value="Adjust Servo Angle" style="rounded=1;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="150" y="450" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="decision_to_servo" edge="1" parent="1" source="decision" target="change_servo">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="225" y="370" as="sourcePoint" />
            <mxPoint x="225" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- No (Continue) -->
        <mxCell id="continue" value="Continue Moving" style="rounded=1;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="450" y="450" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="decision_to_continue" edge="1" parent="1" source="decision" target="continue">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="525" y="370" as="sourcePoint" />
            <mxPoint x="525" y="450" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Loop Back -->
        <mxCell id="loop_back" value="Loop Back" edge="1" parent="1" source="change_servo" target="esp1_loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="loop_back_2" value="Loop Back" edge="1" parent="1" source="continue" target="esp1_loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
